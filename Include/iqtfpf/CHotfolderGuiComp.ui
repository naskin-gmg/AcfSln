      <string notr="true">QTreeView
{
	selection-color: palette(base); 
	selection-background-color: palette(base); 
}

QTreeView::item
{
	min-height: 22px;
	border-radius: 4px;
	border: 1px solid rgb(173,186,241);
	margin-left: 4px;
	margin-right: 4px;
 }

QTreeView::item:!has-children
{
	border: 0px;
	border-bottom: 1px solid rgb(173,186,241);
 }

QTreeView::item:has-children
{
	margin-top: 4px;
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1, stop: 0 rgba(173,186,255,25), stop: 1 rgba(173,186,255,50));
 }

