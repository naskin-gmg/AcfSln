     <property name="styleSheet">
      <string notr="true">QTreeView
{
	selection-color: palette(base); 
	selection-background-color: palette(base); 
}

QTreeView::item
{
	min-height: 22px;
	border-radius: 4px;
	border: 1px solid palette(mid);
	margin-left: 4px;
	margin-right: 4px;
 }

QTreeView::item:!has-children
{
	border: 0px;
	border-bottom: 1px solid  palette(mid);
 }

QTreeView::item:has-children
{
	margin-top: 4px;
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1, stop: 0 rgba(250,250,250,192), stop: 1 rgba(231,231,231,192));
 }

 QTreeView::item:!has-children:!has-siblings
{
	border-bottom: 0px;
 }


QTreeView::item:selected:!has-children
{
	background: palette(highlight);
 }

QTreeView::item:selected:has-children
{
	color: black;
 }

QTreeView::branch
{
	background: palette(base);
}</string>
